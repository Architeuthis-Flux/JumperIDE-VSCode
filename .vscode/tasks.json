{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "npm",
      "script": "build",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "clear": true
      }
    },
    {
      "label": "watch",
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "group": "build",
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": [{ "regexp": "^(?!.*).$", "file": 1, "line": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[esbuild\\] watching",
          "endsPattern": "\\[esbuild\\] (build complete|build finished)"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    }
  ]
}
