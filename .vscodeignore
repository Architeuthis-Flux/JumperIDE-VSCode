# Source — esbuild already bundled it into dist/extension.js
src/**
tsconfig.json
esbuild.js
*.map

# Dev tooling (stub sync runs at package time, not shipped)
scripts/**
_validate_*.js

# Dev-only
.vscode/**
.gitignore
.gitattributes
.github/**
*.vsix

# Big assets we don't ship — only the icons used by the manifest matter
icons/JumperlessWheelMain.png
icons/icon4096fc.svg
icons/iconPlay2048.png
icons/iconStop2048.png

# node_modules: exclude EVERYTHING, then selectively re-include only the
# runtime dependencies of `serialport` (which we mark external in esbuild
# because it has a native node-addon binding that can't be bundled).
node_modules/**
!node_modules/serialport/**
!node_modules/@serialport/**
!node_modules/debug/**
!node_modules/ms/**
!node_modules/node-addon-api/**
!node_modules/node-gyp-build/**

# Drop developer-only files to keep the package small. NOTE: these have no
# effect inside the node_modules re-includes above — vsce's negated patterns
# (!...) override every exclusion, so e.g. @serialport's .d.ts files still
# ship. They do still apply to the rest of the tree (e.g. dist/*.js.map).
# Do NOT add **/CHANGELOG.md here: it would exclude the root CHANGELOG.md,
# which the Marketplace uses for the extension's Changelog tab.
**/test/**
**/tests/**
**/__tests__/**
**/*.test.js
**/*.spec.js
**/*.d.ts
**/*.ts
**/*.map
**/CONTRIBUTING.md
**/.travis.yml
**/.eslintrc*
